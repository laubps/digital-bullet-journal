# ─────────────────────────────────────────────────────────────
# Digital Bullet Journal — environment variable template
#
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real credentials.
# ─────────────────────────────────────────────────────────────

# ── OCI Vault (Step 3) ────────────────────────────────────────
# OCID of the Vault secret that contains DB credentials as JSON:
#   { "db_user", "db_password", "wallet_password", "connection_string" }
VAULT_SECRET_OCID=

# Absolute path to your OCI config file (usually ~/.oci/config)
# On Windows use forward slashes to avoid dotenv misreading backslashes: C:/Users/...
OCI_CONFIG_FILE=

# Profile name inside OCI_CONFIG_FILE to use for authentication
OCI_CONFIG_PROFILE=DEFAULT

# ── Oracle Database — wallet (Step 3) ────────────────────────
# Absolute path to the directory containing the Oracle wallet files
# (tnsnames.ora, sqlnet.ora, ewallet.p12, cwallet.sso, etc.)
# On Windows use forward slashes: C:/Users/...
DB_WALLET_LOCATION=

# ── Authentication (Step 4) ───────────────────────────────────
# Long random string used to sign JWT tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Token expiry (e.g. "7d", "24h")
JWT_EXPIRES_IN=7d

# ── Claude API (Step 8) ───────────────────────────────────────
# Anthropic API key — obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=
