# ─────────────────────────────────────────────────────────────
# Digital Bullet Journal — environment variable template
#
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real credentials.
# ─────────────────────────────────────────────────────────────

# ── Oracle Autonomous Database ────────────────────────────────
# Username for the DB schema (e.g. ADMIN or a dedicated schema user)
DB_USER=

# DB password
DB_PASSWORD=

# TNS alias from tnsnames.ora, or a full Easy Connect string
DB_CONNECTION_STRING=

# Absolute path to the directory containing the Oracle wallet files
# (tnsnames.ora, sqlnet.ora, cwallet.sso, ewallet.p12)
DB_WALLET_LOCATION=

# ── Authentication ────────────────────────────────────────────
# Long random string used to sign JWT tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Token expiry (e.g. "7d", "24h")
JWT_EXPIRES_IN=7d

# ── Claude API (added in Step 8) ──────────────────────────────
# Anthropic API key — obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=
